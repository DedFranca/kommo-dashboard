# Copie para `.env` (local) e configure as mesmas variáveis na Vercel.

# =============================================================================
# BANCO DE DADOS — Supabase PostgreSQL (obrigatório para Prisma)
# =============================================================================
# O app usa Prisma direto no Postgres. NÃO use NEXT_PUBLIC_SUPABASE_* aqui.
#
# Supabase → Project Settings → Database → Connection string:
#
# 1) DATABASE_URL = "Transaction pooler" (porta 6543, mode Session, ?pgbouncer=true)
# 2) DIRECT_URL   = "Direct connection" (porta 5432) — usado em migrations
#
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:5432/postgres"

# Opcional — chaves públicas Supabase (não usadas pelo Prisma hoje; reservado)
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Desenvolvimento local sem Supabase (SQLite — não funciona na Vercel):
# DATABASE_URL="file:./dev.db"
# Remova directUrl do schema ou use DATABASE_URL como DIRECT_URL também.

# =============================================================================
# AUTENTICAÇÃO
# =============================================================================
# Gere segredos fortes: openssl rand -base64 32
AUTH_SECRET="troque-por-um-segredo-longo"
JWT_SECRET="opcional-alias-do-auth-secret"
NEXTAUTH_SECRET="opcional-alias-do-auth-secret"
APP_ENCRYPTION_KEY="chave-para-criptografar-tokens-kommo-no-banco"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL_DAYS="7"
AUTH_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# =============================================================================
# KOMMO CRM — somente servidor (nunca exponha ao cliente)
# =============================================================================
KOMMO_SUBDOMAIN="drivanramos"
KOMMO_ACCESS_TOKEN="seu-token-bearer-aqui"

# Opcional: URL base completa (NÃO use api-c.kommo.com)
# KOMMO_API_BASE_URL="https://drivanramos.kommo.com/api/v4"

# IDs de status won/lost (opcional — detectados via pipelines se omitidos)
# KOMMO_WON_STATUS_IDS=142
# KOMMO_LOST_STATUS_IDS=143

# Cache de métricas (minutos, mínimo 5)
# KOMMO_METRICS_CACHE_TTL_MINUTES=20

# Segredo para refresh via GET /api/kommo/refresh?secret=
# KOMMO_REFRESH_SECRET=seu-segredo

# Vercel Cron envia Authorization: Bearer ${CRON_SECRET}
# CRON_SECRET=seu-segredo-cron

# Campos customizados Kommo (opcional)
# KOMMO_ORIGIN_FIELD_CODES=origem
# KOMMO_LOCATION_FIELD_CODES=local da consulta,local,cidade
# KOMMO_DOCTOR_FIELD_CODES=médico,medico

# OAuth Kommo (futuro)
# KOMMO_CLIENT_ID=
# KOMMO_CLIENT_SECRET=
# KOMMO_REDIRECT_URI=https://seu-dominio.vercel.app/api/auth/kommo/callback
